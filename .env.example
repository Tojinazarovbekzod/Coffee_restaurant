# Production environment — copy to .env on the EC2 instance and fill in real values.
# Never commit .env to git.

# Docker Hub image (e.g. johndoe/coffee-restaurant)
DOCKER_IMAGE=your-dockerhub-username/coffee-restaurant

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-50-chars-min
ALLOWED_HOSTS=your-ec2-public-ip-or-domain

# MariaDB
DB_NAME=coffee_db
DB_USER=coffee_user
DB_PASSWORD=change-me-strong-db-password
DB_ROOT_PASSWORD=change-me-strong-root-password
